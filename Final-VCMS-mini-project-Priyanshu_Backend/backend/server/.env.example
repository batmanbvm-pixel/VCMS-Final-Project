# Backend Environment Example
PORT=5000
MONGO_URI=mongodb://localhost:27017/vcms
JWT_SECRET=replace_with_secure_secret
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Email (Gmail SMTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password

# Optional: redirect ALL outgoing OTP/system emails to one inbox (testing)
# Example: naruto1821uzumaki@gmail.com
EMAIL_FORCE_TO=

# Gemini AI configuration
# Primary key (single)
GEMINI_API_KEY=your_primary_gemini_key

# Optional key rotation pool (comma-separated)
# Used automatically when quota/model issues happen
GEMINI_API_KEYS=your_key_1,your_key_2
