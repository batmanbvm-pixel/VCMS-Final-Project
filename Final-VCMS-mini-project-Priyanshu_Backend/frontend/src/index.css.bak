@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 220 15% 97%;
    --foreground: 220 10% 10%;

    --card: 0 0% 100%;
    --card-foreground: 220 10% 10%;

    --popover: 0 0% 100%;
    --popover-foreground: 220 10% 10%;

    --primary: 221 83% 53%;
    --primary-foreground: 0 0% 100%;

    --secondary: 262 83% 58%;
    --secondary-foreground: 0 0% 100%;

    --muted: 220 15% 95%;
    --muted-foreground: 220 10% 45%;

    --accent: 221 90% 96%;
    --accent-foreground: 221 83% 53%;

    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 100%;

    --border: 220 13% 91%;
    --input: 220 13% 91%;
    --ring: 221 83% 53%;

    --radius: 0.75rem;

    --sidebar-background: 220 15% 5%;
    --sidebar-foreground: 220 15% 95%;
    --sidebar-primary: 221 83% 53%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 220 15% 12%;
    --sidebar-accent-foreground: 220 15% 95%;
    --sidebar-border: 220 15% 15%;
    --sidebar-ring: 221 83% 53%;

    --success: 142 76% 36%;
    --success-foreground: 0 0% 100%;
    --warning: 38 92% 50%;
    --warning-foreground: 0 0% 100%;
    --info: 199 89% 48%;
    --info-foreground: 0 0% 100%;
  }

  .dark {
    --background: 215 25% 8%;
    --foreground: 210 20% 95%;

    --card: 215 25% 12%;
    --card-foreground: 210 20% 95%;

    --popover: 215 25% 12%;
    --popover-foreground: 210 20% 95%;

    --primary: 199 89% 48%;
    --primary-foreground: 0 0% 100%;

    --secondary: 170 55% 40%;
    --secondary-foreground: 0 0% 100%;

    --muted: 215 20% 18%;
    --muted-foreground: 215 15% 60%;

    --accent: 199 40% 20%;
    --accent-foreground: 199 89% 70%;

    --destructive: 0 62% 40%;
    --destructive-foreground: 0 0% 100%;

    --border: 215 20% 22%;
    --input: 215 20% 22%;
    --ring: 199 89% 48%;

    --sidebar-background: 215 25% 6%;
    --sidebar-foreground: 210 20% 90%;
    --sidebar-primary: 199 89% 48%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 215 25% 15%;
    --sidebar-accent-foreground: 210 20% 90%;
    --sidebar-border: 215 20% 18%;
    --sidebar-ring: 199 89% 48%;

    --success: 152 55% 38%;
    --success-foreground: 0 0% 100%;
    --warning: 38 85% 45%;
    --warning-foreground: 0 0% 100%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground font-sans antialiased;
    font-family: 'Inter', sans-serif;
  }

  h1 {
    @apply text-4xl font-bold tracking-tight leading-tight;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  h2 {
    @apply text-2xl font-bold tracking-tight leading-snug;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  h3 {
    @apply text-xl font-semibold tracking-tight;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  h4, h5, h6 {
    @apply font-semibold;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  p {
    @apply leading-relaxed;
  }
}

@layer components {
  .gradient-primary {
    @apply bg-gradient-to-r from-primary via-blue-500 to-secondary;
  }
  
  .gradient-secondary {
    @apply bg-gradient-to-br from-violet-500 via-purple-500 to-pink-500;
  }
  
  .gradient-success {
    @apply bg-gradient-to-r from-emerald-500 to-teal-500;
  }

  .gradient-card {
    @apply bg-gradient-to-br from-white to-slate-50;
  }

  .glass {
    @apply bg-white/80 backdrop-blur-xl border border-white/20;
  }

  .card-modern {
    @apply bg-white border border-slate-200/60 rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300;
  }

  .btn-gradient-primary {
    @apply gradient-primary text-white shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 transition-all duration-300;
  }

  .btn-gradient-secondary {
    @apply gradient-secondary text-white shadow-lg shadow-purple-500/25 hover:shadow-xl hover:shadow-purple-500/30 transition-all duration-300;
  }
}

@layer utilities {
  .animate-fade-in {
    animation: fadeIn 0.5s ease-in;
  }

  .animate-slide-up {
    animation: slideUp 0.6s ease-out;
  }

  .animate-scale-in {
    animation: scaleIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
}

